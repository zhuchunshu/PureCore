# PureCore 配置 / PureCore Configuration
# 前端 / Frontend
FRONTEND_PORT=9001

# 后端 / Backend
BACKEND_PORT=9002

# 数据库 / Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=purecore
DB_SSLMODE=disable

# 应用 / App
APP_ENV=local
APP_DEBUG=true

# 主题 / Theme
# DaisyUI 主题名称，可用值: light, dark, cupcake, bumblebee, emerald, corporate, synthwave, retro, cyberpunk, valentine, halloween, garden, forest, aqua, lofi, pastel, fantasy, wireframe, black, luxury, dracula, cmyk, autumn, business, acid, lemonade, night, coffee, winter, dim, nord, sunset
# 修改此值即可全局切换主题，无需修改代码
THEME=sunset

# 管理员 / Admin
ADMIN_ROUTE_PREFIX=control-panel
VITE_ADMIN_ROUTE_PREFIX=control-panel
JWT_SECRET=your-jwt-secret-here
